# OpenCV Image Editor - environment configuration
# Copy to .env and adjust as needed

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Image limits
MAX_IMAGE_SIZE_MB=10
MAX_IMAGE_DIMENSION=1536

# Model paths (downloaded by scripts/download_models.py at build time)
MODEL_DIR=./models

# Rate limiting (per-IP)
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_PERIOD=60

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090
